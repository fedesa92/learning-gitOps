{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "types": [
            "vite/client",
            "jest",
            "@testing-library/jest-dom"
        ],
        "noEmit": true
    },
    "include": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/__tests__/**/*",
        "test/**/*.ts",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "src/**/__tests__/**/*.spec.ts",
        "src/**/__tests__/**/*.spec.tsx",
    ],
    "exclude": []
}
